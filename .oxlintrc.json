{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": { "browser": true },
  "plugins": [
    "eslint",
    "jsx-a11y",
    "oxc",
    "promise",
    "react-perf",
    "react",
    "typescript",
    "unicorn"
  ],
  "categories": {
    "correctness": "error",
    "nursery": "off",
    "pedantic": "error",
    "perf": "error",
    "restriction": "error",
    "style": "error",
    "suspicious": "error"
  },
  "rules": {
    "no-unused-vars": "off",
    "capitalized-comments": "off",
    "id-length": "off",
    "max-params": "off",
    "max-statements": "off",
    "no-magic-numbers": "off",
    "no-underscore-dangle": "off",
    "prefer-destructuring": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "typescript/prefer-for-of": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-null": "off"
  }
}
