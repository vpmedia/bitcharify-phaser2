{
  "name": "@vpmedia/bitcharify-phaser2",
  "version": "1.12.0",
  "description": "@vpmedia/bitcharify-phaser2 is the integration add-on for the @vpmedia/bitcharify bitmap font generator with the Phaser v2 game engine",
  "author": "Andras Csizmadia <andras@vpmedia.hu> (www.vpmedia.hu)",
  "license": "MIT",
  "homepage": "https://github.com/vpmedia/bitcharify-phaser2#readme",
  "bugs": {
    "url": "https://github.com/vpmedia/bitcharify-phaser2/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vpmedia/bitcharify-phaser2.git"
  },
  "keywords": [
    "bitcharify",
    "phaser",
    "phaser2"
  ],
  "main": "./src/index.js",
  "types": "./types/index.d.ts",
  "type": "module",
  "dependencies": {
    "@vpmedia/phaser": "^1.101.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.0",
    "typescript": "6.0.0-dev.20260315",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "build": "exit 0",
    "check": "pnpm lint && pnpm test && pnpm typecheck",
    "test": "vitest --coverage --pass-with-no-tests",
    "lint": "oxlint src",
    "typecheck": "tsc",
    "format": "oxfmt --write \"./**/*.{js,jsx,mjs,cjs,ts,tsx,json,css}\""
  }
}
